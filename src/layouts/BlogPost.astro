---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={title} description={description}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
    <!-- Header -->
    <header class="mb-8 pb-6 border-b border-ink-100">
      <div class="flex flex-wrap gap-2 mb-4">
        {tags.map(tag => <span class="tag-pill">{tag}</span>)}
      </div>
      <h1 class="text-3xl sm:text-4xl font-semibold text-ink-900 leading-tight mb-3">
        {title}
      </h1>
      <p class="text-lg text-ink-500 mb-4">{description}</p>
      <time class="text-sm text-ink-400" datetime={pubDate.toISOString()}>
        Published {formattedDate}
      </time>
    </header>

    <!-- Body -->
    <div class="prose-newsroom">
      <slot />
    </div>

    <!-- Back link -->
    <div class="mt-12 pt-6 border-t border-ink-100">
      <a href="/personal-newsroom/" class="text-brand-600 hover:underline text-sm">
        ← Back to all briefings
      </a>
    </div>
  </article>
</Base>
